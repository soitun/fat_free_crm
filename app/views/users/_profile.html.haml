.remote
  = form_for(@user, html: one_submit_only, remote: true) do |f|
    = link_to_close edit_user_path(@user)

    = f.error_messages object_name: t('user')

    .section
      .grid
        %div
          .label.top #{t :first_name}:
          = f.text_field :first_name

        %div
          .label.top #{t :last_name}:
          = f.text_field :last_name

        %div
          .label.top #{t :job_title}:
          = f.text_field :title

        %div
          .label.top #{t :company}:
          = f.text_field :company

    .subtitle #{t :contact_info}
    .section
      .grid
        %div
          .label.top #{t :blog}:
          = f.url_field :blog

        %div
          .label.top.req #{t :email}:
          = f.email_field :email

        %div
          .label.top #{t :alt_email}:
          = f.email_field :alt_email

        %div
          .label #{t :phone}:
          = phone_field_with_pattern(f, :phone)

        %div
          .label #{t :mobile}:
          = phone_field_with_pattern(f, :mobile)

        %div
          .label #{t :google}:
          = f.text_field :google

        %div
          .label #{t :facebook}:
          = f.text_field :facebook

        %div
          .label #{t :twitter}:
          = f.text_field :twitter

        %div
          .label #{t :linked_in}:
          = f.text_field :linkedin

        %div
          .label #{t :instagram}:
          = f.text_field :instagram

        %div
          .label #{t :mastodon}:
          = f.text_field :mastodon

        %div
          .label #{t :bluesky}:
          = f.text_field :bluesky

        %div
          .label #{t :zoom}:
          = f.text_field :zoom

        %div
          .label #{t :teams}:
          = f.text_field :teams

        %div
          .label #{t :signal}:
          = f.text_field :signal

    .subtitle #{t :email_notifications}
    .section
      .row-full-width
        .check_box
          = f.check_box :subscribe_to_comment_replies
          = f.label :subscribe_to_comment_replies, t(:subscribe_to_comment_replies), class: 'check_box'
      .row-full-width
        .checkbox
          = f.check_box :receive_assigned_notifications
          = f.label :receive_assigned_notifications, t(:receive_assigned_notifications), class: 'check_box'
    .buttonbar
      = f.submit t :save_profile
      #{t :or}
      = link_to_cancel edit_user_path(@user)

  = hook(:profile_user_bottom, self)
%br
