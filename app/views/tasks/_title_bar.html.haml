.title_tools#menu
  = link_to_inline(:edit_task, edit_task_path(@task), text: t(:edit)) + " | "
  = link_to_function(t(:delete) + '?', confirm_delete(@task))
.title_tools#buttons
  = view_buttons
.title#title
  = h(@task.name)
  = image_tag("loading.gif", size: :thumb, id: "loading", style: "display: none;")

%div#edit_task{ hidden }
